{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "defaultProject": "company-social-platform",
  "projects": {
    "company-social-platform": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/company-social-platform",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.svg",
              "src/manifest.webmanifest",
              "src/ngsw-config.json"
            ],
            "styles": ["src/styles.css"],
            "scripts": [],
            "serviceWorker": true,
            "ngswConfigPath": "src/ngsw-config.json"
          },
          "configurations": {
            "sit": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.sit.ts"
                }
              ]
            },
            "uat": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.uat.ts"
                }
              ]
            },
            "preprod": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.preprod.ts"
                }
              ]
            },
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "company-social-platform:build"
          },
          "configurations": {
            "sit": {
              "buildTarget": "company-social-platform:build:sit"
            },
            "uat": {
              "buildTarget": "company-social-platform:build:uat"
            },
            "preprod": {
              "buildTarget": "company-social-platform:build:preprod"
            },
            "production": {
              "buildTarget": "company-social-platform:build:production"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
